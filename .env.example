# Database
DATABASE_URL=postgresql+asyncpg://scuser:scpassword@localhost:5432/supplychain
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supplychain
DB_USER=scuser
DB_PASSWORD=scpassword

# LLM APIs
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Data APIs (all free tier)
COMTRADE_API_KEY=your_un_comtrade_api_key_here
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
NEWSAPI_KEY=your_newsapi_org_key_here
MARINE_TRAFFIC_API_KEY=your_marine_traffic_api_key_here

# App settings
DEBUG=false
LOG_LEVEL=INFO

# HITL governance settings
DEFAULT_APPROVAL_TIMEOUT_HOURS=24
AUTO_APPROVE_COST_THRESHOLD_USD=10000.0

# Simulation defaults
DEFAULT_MC_ITERATIONS=1000
MAX_MC_ITERATIONS=10000

# Sovereign / air-gapped mode (set to true for offline deployment)
SOVEREIGN_MODE=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:70b
