# Copy from .env.example and fill in your API keys
DATABASE_URL=postgresql+asyncpg://scuser:scpassword@localhost:5432/supplychain
DB_HOST=localhost
DB_PORT=5432
DB_NAME=supplychain
DB_USER=scuser
DB_PASSWORD=scpassword

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

COMTRADE_API_KEY=
OPENWEATHERMAP_API_KEY=
NEWSAPI_KEY=

DEBUG=true
LOG_LEVEL=INFO

DEFAULT_APPROVAL_TIMEOUT_HOURS=24
AUTO_APPROVE_COST_THRESHOLD_USD=10000.0
DEFAULT_MC_ITERATIONS=1000
MAX_MC_ITERATIONS=10000

SOVEREIGN_MODE=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:70b
